{
  "name": "@goaldrop/service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import ../../scripts/load-root-env.mjs --import tsx --watch src/cli.ts api",
    "dev:indexer": "node --import ../../scripts/load-root-env.mjs --import tsx --watch src/cli.ts chain-indexer",
    "start": "node --import ../../scripts/load-root-env.mjs dist/cli.js api",
    "start:txline": "node --import ../../scripts/load-root-env.mjs dist/cli.js txline-listener",
    "start:oracle": "node --import ../../scripts/load-root-env.mjs dist/cli.js oracle-worker",
    "start:settlement": "node --import ../../scripts/load-root-env.mjs dist/cli.js settlement-worker",
    "start:indexer": "node --import ../../scripts/load-root-env.mjs dist/cli.js chain-indexer",
    "start:demo": "node --import ../../scripts/load-root-env.mjs dist/cli.js demo-controller",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src",
    "test:unit": "vitest run src",
    "test:load": "tsx src/registration-burst.load.ts && tsx src/claim-burst.load.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/sensible": "6.0.4",
    "@fastify/swagger": "9.8.1",
    "@fastify/swagger-ui": "6.1.0",
    "@goaldrop/db": "workspace:*",
    "@goaldrop/protocol": "workspace:*",
    "@goaldrop/solana-client": "workspace:*",
    "@goaldrop/txline-adapter": "workspace:*",
    "@noble/hashes": "2.2.0",
    "@solana/spl-token": "0.4.15",
    "@solana/web3.js": "1.98.4",
    "bs58": "6.0.0",
    "fastify": "5.10.0",
    "prom-client": "15.1.3",
    "tweetnacl": "1.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1"
  }
}
