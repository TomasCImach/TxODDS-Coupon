[Unit]
Description=Cloudflare Tunnel for GoalDrop API
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/cloudflared --no-autoupdate tunnel run --token-file /etc/cloudflared/goaldrop.token
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
