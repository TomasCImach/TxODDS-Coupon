NODE_ENV=development
HOST=127.0.0.1
PORT=4000
TRUST_PROXY_HOPS=0
PUBLIC_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://goaldrop:goaldrop@localhost:5432/goaldrop
SOLANA_CLUSTER=devnet
SOLANA_HTTP_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_RPC_URL=wss://api.devnet.solana.com
# Replace both placeholder addresses with the deployed program and classic reward mint.
GOALDROP_PROGRAM_ID=11111111111111111111111111111111
GOALDROP_REWARD_MINT=11111111111111111111111111111111
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
TXLINE_SERVICE_LEVEL=1
ROUND_DURATION_SECONDS=120
LIVE_EVENT_MAX_LATENESS_SECONDS=60
DEFAULT_HARD_EXPIRY_SECONDS=28800
TXLINE_LISTENER_ENABLED=true
TXLINE_PUBLIC_OUTPUT_ENABLED=false
TXLINE_RAW_RETENTION_ENABLED=false
DEMO_MODE_ENABLED=true
DEMO_FAUCET_ENABLED=true
# One wallet-signed distribution per sponsor wallet; 500 GOAL at six decimals.
DEMO_FAUCET_AMOUNT_BASE_UNITS=500000000
# Automatically rotated Devnet demo campaigns: 8 goals, 5 winners, 1 GOAL each.
DEMO_ROUND_COUNT=8
DEMO_REWARD_AMOUNT_BASE_UNITS=1000000
DEMO_WINNER_CAP=5
DEMO_CAMPAIGN_LIFETIME_SECONDS=82800
LOG_LEVEL=info
# Role-scoped secrets. Use JSON keypair byte arrays or base64 only in the role that needs them.
RECEIPT_CAPABILITY_KEY=
RELAYER_KEYPAIR=
ORACLE_KEYPAIR=
DEMO_AUTHORITY_KEYPAIR=
# Devnet-only campaign sponsor and GOAL mint authority. Scoped to demo-controller.
OPERATOR_KEYPAIR=
FEE_PAYER_KEYPAIR=
# Devnet judge-campaign admission floor validated by the deployment evidence.
FEE_PAYER_MIN_LAMPORTS=500000000
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=
TXLINE_RAW_ENCRYPTION_KEY=
# Optional legacy campaign imported once for safe refund and fixture cleanup.
DEMO_CAMPAIGN=

# Next.js public/runtime configuration.
API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_REWARD_MINT=11111111111111111111111111111111
NEXT_PUBLIC_REWARD_DECIMALS=6
# Devnet uses the Passkeys sandbox/default configuration. Actual production
# deployments must set this to production and provide an App ID.
NEXT_PUBLIC_DEPLOYMENT_TIER=devnet
NEXT_PUBLIC_PASSKEY_APP_ID=
NEXT_PUBLIC_DEMO_CAMPAIGN=
